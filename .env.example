# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Path to your Financial Tracker Excel file (default: same directory as bot)
EXCEL_PATH=./Financial_Tracker.xlsx

# Your Telegram user ID (for access control, optional)
# Get it by messaging @userinfobot on Telegram
ALLOWED_USER_IDS=

# Timezone
TIMEZONE=Asia/Jakarta

# OpenAI API key (optional — enables AI chat, image & PDF analysis features)
OPENAI_API_KEY=your_openai_api_key_here

# Path to nullclaw binary (for NLP parsing of Indonesian financial messages)
NULLCLAW_PATH=/usr/local/bin/nullclaw
